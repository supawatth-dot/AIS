# ──────────────────────────────────────────────
# AIS — Environment Configuration
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# App
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
LOG_DIR=./logs

# Security — CHANGE IN PRODUCTION
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING_HERE
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins, empty = all)
ALLOWED_ORIGINS=https://your-domain.com

# Database
DB_DIALECT=postgres
DATABASE_URL=postgresql://ais_user:ais_password@localhost:5432/ais_db

# PostgreSQL (for docker-compose.prod.yml)
POSTGRES_DB=ais_db
POSTGRES_USER=ais_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Email — leave empty to disable notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=AIS System <noreply@your-domain.com>

# Frontend URL (used in email notification links)
FRONTEND_URL=https://your-domain.com
